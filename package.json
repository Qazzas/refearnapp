{
  "name": "refearnapp-monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "launch:tracker": "pnpm --filter @repo/tracking-worker run deploy:self",
    "deploy:tracker": "pnpm --filter @repo/tracking-worker exec wrangler deploy --config wrangler.toml --keep-vars",
    "logs:tracker": "pnpm --filter @repo/tracking-worker exec wrangler tail",
    "db:setup": "pnpm --filter @repo/dashboard run db:setup",
    "deploy:main": "pnpm --filter @repo/tracking-worker exec bun scripts/sync-main.js && pnpm --filter @repo/tracking-worker exec wrangler deploy --keep-vars",
    "logs:main": "pnpm --filter @repo/tracking-worker exec bun scripts/sync-main.js && pnpm --filter @repo/tracking-worker exec wrangler tail",
    "db:database:reset": "pnpm --filter @repo/dashboard db:database:reset",
    "lint": "turbo run lint",
    "lint:unused": "eslint . --config eslint.unused.config.mjs",
    "lint:unused:fix": "eslint . --config eslint.unused.config.mjs --fix",
    "clean": "turbo run clean && rm -rf node_modules",
    "logs": "wrangler tail --filter @repo/tracking-worker"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "turbo": "latest"
  }
}