---
// src/components/Hero.astro
---

<section
  id="hero"
  class="relative overflow-hidden px-6 pt-24 pb-16 md:pt-32 md:pb-28"
>
  <div class="absolute inset-0 -z-10">
    <div
      class="from-secondary/80 to-background/20 absolute inset-0 bg-linear-to-b"
    >
    </div>
    <div
      class="bg-primary/10 animate-float absolute top-1/4 left-1/4 h-64 w-64 rounded-full opacity-70 blur-3xl filter"
    >
    </div>
    <div
      class="animate-float animation-delay-300 absolute top-1/3 right-1/4 h-96 w-96 rounded-full bg-blue-400/10 opacity-70 blur-3xl filter"
    >
    </div>
  </div>

  <div class="container mx-auto max-w-5xl">
    <div class="animate-fade-in space-y-8 text-center">
      <h1
        class="text-4xl leading-[1.1] font-extrabold tracking-tight text-balance text-slate-900 md:text-7xl"
      >
        Grow Your Revenue with Affiliates on <span class="text-primary"
          >Autopilot</span
        >
      </h1>

      <p
        class="mx-auto max-w-2xl text-lg leading-relaxed font-medium text-balance text-slate-500 md:text-xl"
      >
        Launch your affiliate program in minutes. Easily track every commission
        and pay your affiliates in a few clicks—built specifically for SaaS and
        digital products.
      </p>
      <div class="flex flex-col items-center justify-center pt-8">
        <a
          href="#pricing"
          class="inline-flex items-center justify-center rounded-full bg-linear-to-r from-[#ec4899] via-[#a855f7] to-[#6366f1] px-12 py-5 font-bold text-white shadow-[0_10px_40px_rgba(236,72,153,0.3)] transition-all duration-300 hover:scale-105 active:scale-95 md:px-16 md:py-6"
        >
          <span class="text-xl font-bold tracking-tight md:text-2xl"
            >Get Started</span
          >
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
