---
import Logo from './Logo.astro';
const supportEmail =
  'mailto:support@refearnapp.com?subject=Support%20Request%20-%20RefearnApp';
---

<header
  id="main-header"
  class="fixed top-0 right-0 left-0 z-50 bg-transparent px-3 py-4 transition-all duration-300 ease-in-out"
>
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4">
    <div class="flex flex-1 justify-start">
      <a href="/" class="flex items-center">
        <Logo sizeClass="h-10" />
      </a>
    </div>

    <nav class="hidden flex-1 justify-center space-x-8 lg:flex">
      <a
        href="#features"
        class="nav-link hover:text-primary font-medium whitespace-nowrap text-slate-600 transition-all hover:scale-105"
        >Features</a
      >
      <a
        href="#how-it-works"
        class="nav-link hover:text-primary font-medium whitespace-nowrap text-slate-600 transition-all hover:scale-105"
        >How It Works</a
      >
      <a
        href="#pricing"
        class="nav-link hover:text-primary font-medium whitespace-nowrap text-slate-600 transition-all hover:scale-105"
        >Pricing</a
      >
      <a
        href={supportEmail}
        class="nav-link hover:text-primary font-medium whitespace-nowrap text-slate-600 transition-all hover:scale-105"
        >Support</a
      >
    </nav>

    <div class="hidden flex-1 items-center justify-end gap-4 lg:flex">
      <a
        href="/login"
        class="hover:text-primary text-sm font-semibold text-slate-600 transition-colors"
        >Login</a
      >
      <a
        href="/signup"
        class="bg-primary rounded-full px-5 py-2 text-sm font-semibold text-white transition-all hover:scale-105 hover:bg-slate-800"
        >Signup</a
      >
    </div>

    <button
      id="menu-toggle"
      class="hover:bg-muted rounded-md p-2 text-slate-900 focus:outline-none lg:hidden"
    >
      <svg
        id="menu-icon"
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="4" y1="6" x2="20" y2="6"></line><line
          x1="4"
          y1="12"
          x2="20"
          y2="12"></line><line x1="4" y1="18" x2="20" y2="18"></line>
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="animate-slide-down border-border mx-3 mt-3 hidden rounded-2xl border bg-white/95 px-6 py-8 shadow-lg backdrop-blur-md lg:hidden"
  >
    <nav class="flex flex-col space-y-6">
      <a
        href="#features"
        class="mobile-link text-lg font-medium whitespace-nowrap text-slate-700"
        >Features</a
      >
      <a
        href="#how-it-works"
        class="mobile-link text-lg font-medium whitespace-nowrap text-slate-700"
        >How It Works</a
      >
      <a
        href="#pricing"
        class="mobile-link text-lg font-medium whitespace-nowrap text-slate-700"
        >Pricing</a
      >
      <a
        href={supportEmail}
        class="mobile-link text-lg font-medium whitespace-nowrap text-slate-700"
        >Support</a
      >
      <hr class="border-slate-200" />
      <div class="flex items-center gap-4 pt-2">
        <a
          href="/login"
          class="hover:text-primary text-lg font-medium text-slate-700 transition-colors"
          >Login</a
        >
        <a
          href="/signup"
          class="bg-primary flex-1 rounded-full px-5 py-2.5 text-center text-lg font-bold text-white transition-all hover:bg-slate-800"
        >
          Signup
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  // ... (Your existing JS logic remains the same)
  const header = document.getElementById('main-header');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('bg-white/80', 'backdrop-blur-md', 'shadow-sm');
      header?.classList.remove('bg-transparent');
    } else {
      header?.classList.remove('bg-white/80', 'backdrop-blur-md', 'shadow-sm');
      header?.classList.add('bg-transparent');
    }
  });

  menuToggle?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.toggle('hidden');
    if (menuIcon) {
      menuIcon.innerHTML = isHidden
        ? `<line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="18" x2="20" y2="18"></line>`
        : `<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>`;
    }
  });
</script>
