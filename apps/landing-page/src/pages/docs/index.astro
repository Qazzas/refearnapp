---
import DocsLayout from '../../layouts/DocsLayout.astro';
import EnvConfiguration from '../../components/docs/sections/EnvConfiguration.tsx';
import CloudflareConnect from '../../components/docs/sections/CloudflareConnect.tsx';
import VPSConfig from '../../components/docs/sections/VPSConfig.tsx';
import CoolifySetup from '../../components/docs/sections/CoolifySetup.tsx';
import TrackerDeployment from '../../components/docs/sections/TrackerDeployment.tsx';
import { Globe, Server, Mail, Zap } from 'lucide-react';
---

<DocsLayout title="RefearnApp Documentation">
  <section id="getting-started" class="mb-24 scroll-mt-20">
    <h1 class="mb-6 text-5xl font-black tracking-tight text-slate-900">
      Getting Started
    </h1>
    <p class="mb-10 max-w-3xl text-xl leading-relaxed text-slate-600">
      RefearnApp is a lightweight, self-hosted affiliate tracking
      infrastructure. Ensure you have the following assets ready before
      proceeding.
    </p>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {
        [
          { title: 'Cloudflare', desc: 'DNS & Worker management.', icon: Zap },
          {
            title: 'Domain',
            desc: 'Dedicated root or subdomain.',
            icon: Globe,
          },
          {
            title: 'VPS Server',
            desc: 'Host your dashboard (Hetzner, GCE).',
            icon: Server,
          },
          { title: 'Upstash', desc: 'Serverless Redis & QStash.', icon: Zap },
          { title: 'Email', desc: 'Zoho, Resend, or SMTP.', icon: Mail },
        ].map((item) => (
          <div class="flex gap-4 rounded-2xl border border-slate-100 bg-white p-5 shadow-sm transition-all hover:border-indigo-100 hover:shadow-md">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-50 text-indigo-600">
              <item.icon size={20} />
            </div>
            <div>
              <h4 class="font-bold text-slate-900">{item.title}</h4>
              <p class="text-sm leading-snug text-slate-500">{item.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <hr class="mb-24 border-slate-200" />

  <CloudflareConnect />
  <hr class="mb-24 border-slate-200" />

  <VPSConfig />
  <hr class="mb-24 border-slate-200" />
  <CoolifySetup />
  <hr class="mb-24 border-slate-200" />
  <TrackerDeployment />
  <hr class="mb-24 border-slate-200" />
  <section id="env-variables" class="mb-24 scroll-mt-20">
    <h2 class="mb-2 text-3xl leading-tight font-bold text-slate-900">
      Environment Variables
    </h2>
    <p class="mb-8 font-medium text-slate-600">
      Full configuration reference for your RefearnApp instance.
    </p>
    <div class="rounded-3xl border border-slate-200 bg-white p-2 shadow-sm">
      <EnvConfiguration client:load />
    </div>
  </section>
</DocsLayout>
