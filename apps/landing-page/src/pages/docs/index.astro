---
import DocsLayout from '../../layouts/DocsLayout.astro';
import EnvConfiguration from '../../components/docs/sections/EnvConfiguration.tsx';
import CloudflareConnect from '../../components/docs/sections/CloudflareConnect.tsx';
import VPSConfig from '../../components/docs/sections/VPSConfig.tsx';
import CoolifySetup from '../../components/docs/sections/CoolifySetup.tsx';
import TrackerDeployment from '../../components/docs/sections/TrackerDeployment.tsx';
import DatabaseConfig from '../../components/docs/sections/DatabaseConfig.tsx';
import EmailConfig from '../../components/docs/sections/EmailConfig.tsx';
import PortalSetup from '../../components/docs/sections/PortalSetup.tsx';
import {
  Globe,
  Server,
  Mail,
  Zap,
  MessageCircle,
  ArrowRight,
} from 'lucide-react';
---

<DocsLayout title="RefearnApp Documentation Page">
  <section id="getting-started" class="mb-24 scroll-mt-20">
    <h1 class="mb-6 text-5xl font-black tracking-tight text-slate-900">
      Getting Started
    </h1>
    <p class="mb-10 max-w-3xl text-xl leading-relaxed text-slate-600">
      RefearnApp is a lightweight, self-hosted affiliate tracking
      infrastructure. Ensure you have the following assets ready before
      proceeding.
    </p>

    <div class="mb-12">
      <a
        href="https://discord.gg/fHw9j7P3w9"
        target="_blank"
        class="group relative flex w-full items-center justify-between overflow-hidden rounded-2xl bg-slate-900 p-1 shadow-xl transition-all hover:scale-[1.01] md:w-fit"
      >
        <div class="flex items-center gap-4 px-5 py-4">
          <div class="relative">
            <div
              class="flex h-12 w-12 items-center justify-center rounded-xl bg-indigo-500/20 text-indigo-400"
            >
              <MessageCircle size={28} />
            </div>
            <span class="absolute -top-1 -right-1 flex h-3 w-3">
              <span
                class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex h-3 w-3 rounded-full border-2 border-slate-900 bg-emerald-500"
              ></span>
            </span>
          </div>

          <div>
            <div class="flex items-center gap-2">
              <p
                class="text-[10px] font-black tracking-[0.2em] text-indigo-400 uppercase"
              >
                Support Channel
              </p>
              <span
                class="rounded bg-emerald-500/10 px-1.5 py-0.5 text-[9px] font-bold text-emerald-400 uppercase"
              >
                Online
              </span>
            </div>
            <p class="text-lg font-bold text-white">
              Join Discord for Technical Help
            </p>
            <p class="text-xs text-slate-400">
              Direct access to developers & community
            </p>
          </div>
        </div>

        <div
          class="flex h-full items-center border-l border-slate-800 bg-slate-800/50 px-6 py-4 text-white transition-colors group-hover:bg-indigo-600"
        >
          <ArrowRight size={20} />
        </div>
      </a>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        [
          { title: 'Cloudflare', desc: 'DNS & Worker management.', icon: Zap },
          {
            title: 'Domain',
            desc: 'Dedicated root or subdomain.',
            icon: Globe,
          },
          {
            title: 'VPS Server',
            desc: 'Host your dashboard (Hetzner, GCE).',
            icon: Server,
          },
          { title: 'Upstash', desc: 'Serverless Redis & QStash.', icon: Zap },
          { title: 'Email', desc: 'Zoho, Resend, or SMTP.', icon: Mail },
        ].map((item) => (
          <div class="flex gap-4 rounded-2xl border border-slate-100 bg-white p-5 shadow-sm transition-all hover:border-indigo-100 hover:shadow-md">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-50 text-indigo-600">
              <item.icon size={20} />
            </div>
            <div>
              <h4 class="font-bold text-slate-900">{item.title}</h4>
              <p class="text-sm leading-snug text-slate-500">{item.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <hr class="mb-24 border-slate-200" />

  <CloudflareConnect />
  <hr class="mb-24 border-slate-200" />

  <VPSConfig />
  <hr class="mb-24 border-slate-200" />
  <CoolifySetup />
  <hr class="mb-24 border-slate-200" />
  <TrackerDeployment />
  <hr class="mb-24 border-slate-200" />
  <DatabaseConfig />
  <hr class="mb-24 border-slate-200" />
  <EmailConfig />
  <hr class="mb-24 border-slate-200" />
  <PortalSetup />
  <hr class="mb-24 border-slate-200" />
  <section id="env-variables" class="mb-24 scroll-mt-20">
    <h2 class="mb-2 text-3xl leading-tight font-bold text-slate-900">
      Environment Variables
    </h2>
    <p class="mb-8 font-medium text-slate-600">
      Full configuration reference for your RefearnApp instance.
    </p>
    <div class="rounded-3xl border border-slate-200 bg-white p-2 shadow-sm">
      <EnvConfiguration client:load />
    </div>
  </section>
</DocsLayout>
