---
import DocsLayout from '../../layouts/DocsLayout.astro';
import EnvConfiguration from '../../components/docs/EnvConfiguration.tsx';
import { CheckCircle2, Globe, Server, Mail, Zap } from 'lucide-react';
---

<DocsLayout title="RefearnApp Documentation">
  <section id="getting-started" class="mb-24 scroll-mt-20">
    <h1 class="mb-6 text-5xl font-black tracking-tight text-slate-900">
      Getting Started
    </h1>
    <p class="mb-10 max-w-3xl text-xl leading-relaxed text-slate-600">
      RefearnApp is a lightweight, self-hosted affiliate tracking
      infrastructure. It gives you full ownership of your referral data and
      attribution logic. Before we dive into the installation, ensure you have
      the following assets ready.
    </p>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {
        [
          {
            title: 'Cloudflare Account',
            desc: 'Used for DNS management and Worker deployment.',
            icon: Zap,
          },
          {
            title: 'Dedicated Domain',
            desc: 'A domain or subdomain for your tracking links.',
            icon: Globe,
          },
          {
            title: 'VPS Server',
            desc: 'Host your dashboard (Hetzner, Google Cloud, etc).',
            icon: Server,
          },
          {
            title: 'Upstash Account',
            desc: 'Serverless Redis for real-time click tracking.',
            icon: Zap,
          },
          {
            title: 'Email Provider',
            desc: 'Zoho, Resend, or a custom SMTP server.',
            icon: Mail,
          },
        ].map((item) => (
          <div class="transition-hover flex gap-4 rounded-2xl border border-slate-100 bg-white p-5 shadow-sm hover:border-indigo-100 hover:shadow-md">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-50 text-indigo-600">
              <item.icon size={20} />
            </div>
            <div>
              <h4 class="font-bold text-slate-900">{item.title}</h4>
              <p class="text-sm leading-snug text-slate-500">{item.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <hr class="mb-24 border-slate-200" />

  <section id="cloudflare" class="mb-24 scroll-mt-20">
    <div
      class="mb-4 flex items-center gap-2 font-bold tracking-tighter text-indigo-600 uppercase"
    >
      <Globe size={20} />
      <span>Domain Connectivity</span>
    </div>
    <h2 class="mb-6 text-3xl leading-tight font-bold text-slate-900">
      Cloudflare Configuration
    </h2>

    <div class="prose prose-slate max-w-none space-y-6">
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <h3 class="mt-0 text-lg font-bold text-slate-900">
          Connecting your Domain
        </h3>
        <p>
          RefearnApp utilizes Cloudflare Workers and Pages. You must have your
          domain managed by Cloudflare to proceed.
        </p>

        <ul class="list-none space-y-4 pl-0">
          <li class="flex gap-3">
            <CheckCircle2
              className="mt-1 shrink-0 text-emerald-500"
              size={18}
            />
            <span
              ><strong>New Domains:</strong> Purchase directly through Cloudflare
              Registrar for zero-config setup.</span
            >
          </li>
          <li class="flex gap-3">
            <CheckCircle2
              className="mt-1 shrink-0 text-emerald-500"
              size={18}
            />
            <span
              ><strong>Existing Domains:</strong> Change your Name Servers at your
              registrar (Namecheap, GoDaddy, etc.) to the records shown in your Cloudflare
              dashboard.</span
            >
          </li>
        </ul>
      </div>

      <div class="rounded-2xl border border-amber-100 bg-amber-50/50 p-6">
        <p class="m-0 text-sm text-amber-800 italic">
          <strong>Note:</strong> DNS propagation typically takes minutes but can take
          up to 24 hours.
        </p>
      </div>
    </div>
  </section>

  <hr class="mb-24 border-slate-200" />

  <section id="env-variables" class="mb-24 scroll-mt-20">
    <h2 class="mb-2 text-3xl font-bold text-slate-900">
      Environment Variables
    </h2>
    <p class="mb-8 font-medium text-slate-600">
      Interactive configuration guide for your local and production
      environments.
    </p>
    <div
      class="rounded-3xl border border-slate-200 bg-white p-2 shadow-sm shadow-indigo-100/50"
    >
      <EnvConfiguration client:load />
    </div>
  </section>
</DocsLayout>
