---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import PricingCTA from '../../components/blog/PricingCTA';
import Footer from '../../components/Footer.astro';
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

// Filter for H2s to keep the Sidebar clean
const sections = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ slug: h.slug, text: h.text }));

const CDN_URL = 'https://assets.refearnapp.com';
---

<BlogLayout title={`${entry.data.title} | RefearnApp`} sections={sections}>
  <header class="mb-10">
    <h1 class="mb-2 text-2xl font-black text-slate-900 sm:text-4xl">
      {entry.data.title}
    </h1>
    <time class="text-sm font-medium text-slate-500">{entry.data.date}</time>
  </header>

  <div
    class="mb-16 overflow-hidden rounded-xl border border-slate-200 bg-slate-50 shadow-sm"
  >
    <img
      src={`${CDN_URL}${entry.data.image}`}
      alt={entry.data.title}
      class="block aspect-video h-auto w-full object-cover"
    />
  </div>

  <div class="prose prose-slate prose-indigo max-w-none">
    <Content />
  </div>
</BlogLayout>
<div class="mx-auto max-w-7xl px-6 pb-24 lg:px-8">
  <PricingCTA client:load variant="footer" />
</div>
<Footer />
